{
  "manifest_version": 3,
  "name": "Brave MCP",
  "version": "0.11.0",
  "description": "Bridge Brave tabs to a local daemon for MCP control.",
  "permissions": [
    "alarms",
    "contentSettings",
    "cookies",
    "debugger",
    "scripting",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html"
}
